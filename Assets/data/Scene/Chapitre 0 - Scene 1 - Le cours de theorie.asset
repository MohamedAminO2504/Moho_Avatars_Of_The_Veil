    actor: {fileID: 11400000, guid: 4ba6ffe56ef870b45bced7533be3f254, type: 2}
    actor2: {fileID: 0}
    dialogue: "Amin.\r\nJe devais m\u2019entretenir avec toi.\r\nMais je ne peux
      pas maintenant.\r\nJ\u2019ai une r\xE9union importante avec l\u2019administration.\nPasse
      me voir en fin de journ\xE9e.\r\nJe te donnerai quelques travaux suppl\xE9mentaires
      pour combler ton retard.\r\nRien d\u2019alarmant. Simplement n\xE9cessaire.\r\nBienvenue
      parmi nous."
    typeCard: 0
    variable: 
    cara:
      hp: 0
      hpMax: 0
      atk: 0
      def: 0
      vit: 0
      mag: 0
      esp: 0
    scene: {fileID: 0}
