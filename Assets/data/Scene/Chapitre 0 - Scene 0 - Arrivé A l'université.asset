    battleParam: []
    battleType: 0
  - type: 0
    location: 
    actor: {fileID: 11400000, guid: 31d7ac23f4526404588170d3e411afdb, type: 2}
    actor2: {fileID: 0}
    dialogue: "All\xF4\u2026 Tu m\u2019entends ?\nC\u2019est Hitomi. On devait se
      retrouver ce matin.\r\nJe suis d\xE9j\xE0 dans l\u2019universit\xE9\u2026 mais
      je ne te vois pas.\r\nEst-ce que \xE7a va, tu n\u2019es pas perdu ?\n"
    typeCard: 0
    variable: 
    cara:
      hp: 0
      hpMax: 0
      atk: 0
      def: 0
      vit: 0
      mag: 0
      esp: 0
    scene: {fileID: 0}
    state: 2
    look: 0
    battleParam: []
    battleType: 0
  - type: 0
    location: 
    actor: {fileID: 11400000, guid: 31d7ac23f4526404588170d3e411afdb, type: 2}
    actor2: {fileID: 0}
    dialogue: "D\u2019accord\u2026 je vais t\u2019aider.\r\nPour me trouver,\_ tu
      dois d\u2019abord localiser l\u2019universit\xE9.\r\nPrends la carte Universit\xE9
      et pose-la devant toi, sur la table. "
    typeCard: 0
    variable: 
    cara:
      hp: 0
      hpMax: 0
      atk: 0
      def: 0
      vit: 0
      mag: 0
      esp: 0
    scene: {fileID: 0}
    state: 2
    look: 0
    battleParam: []
    battleType: 0
  - type: 3
    location: L-2
    actor: {fileID: 11400000, guid: c4822420ee5d6e947a238974055817a5, type: 2}
    actor2: {fileID: 0}
    dialogue: "Bienvenue dans le Grand Hall.\r\nC\u2019est le c\u0153ur de l\u2019universit\xE9.\r\nQuand
      on est nouveau\u2026 c\u2019est normal de se sentir un peu impressionn\xE9
      ici.\r\nTa premi\xE8re journ\xE9e est simple.\r\nTu as deux cours : \r\nUn
      cours th\xE9orique\u2026\r\net un cours de combat.\r\nLe cours th\xE9orique
      t\u2019aidera \xE0 comprendre notre monde.\r\nEt le cours de combat\u2026\r\n\u2026
      est assez parlant, non ?\r\nMais avant tout\u2026\r\nOn va passer aux dortoirs.\r\nTu
      dois te changer et enfiler ton uniforme.\r\nDonc prends la carte **Dortoirs**."
    typeCard: 0
    variable: 
    cara:
      hp: 0
      hpMax: 0
      atk: 0
      def: 0
      vit: 0
      mag: 0
      esp: 0
    scene: {fileID: 0}
    state: 2
    look: 0
    battleParam: []
    battleType: 0
