  m_Name: "Chapitre 0 - Scene 0 - Arriv\xE9 A l'universit\xE9"
  m_EditorClassIdentifier: Assembly-CSharp::Scene
  steps:
  - type: 3
    location: 
    actor: {fileID: 11400000, guid: b0be76f998676744c975cf19bbe404f9, type: 2}
    actor2: {fileID: 0}
    dialogue: "Enchant\xE9e et heureuse de faire enfin ta connaissance.\r\nBienvenue
      \xE0 l\u2019universit\xE9.\r\nOn va commencer la journ\xE9e ensemble.\r\nJe
      vais te guider pas \xE0 pas."
    typeCard: 0
    variable: 
    cara:
      hp: 0
      hpMax: 0
      atk: 0
      def: 0
      vit: 0
      mag: 0
      esp: 0
    scene: {fileID: 0}
    state: 2
